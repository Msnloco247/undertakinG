---
interface Props {
  title?: string;
  description?: string;
}
const {
  title = 'EmprendeIA — Analiza tu Emprendimiento con IA',
  description = 'Responde algunas preguntas y recibe un análisis FODA, propuesta de valor y plan de pasos con presupuesto para tu emprendimiento.',
} = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=Instrument+Sans:wght@400;500;600&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  /* ── Design Tokens ─────────────────────────────────────────────────────────── */
  :root {
    /* Surfaces — carbón + pizarra */
    --bg-canvas:   hsl(220 14% 7%);
    --bg-base:     hsl(220 13% 10%);
    --bg-raised:   hsl(220 12% 13%);
    --bg-overlay:  hsl(220 11% 16%);
    --bg-control:  hsl(220 10% 9%);

    /* Borders */
    --border-subtle:   rgba(255 255 255 / 0.05);
    --border-default:  rgba(255 255 255 / 0.09);
    --border-emphasis: rgba(255 255 255 / 0.16);
    --border-focus:    hsl(42 95% 55% / 0.7);

    /* Text hierarchy */
    --text-primary:   hsl(40 20% 92%);
    --text-secondary: hsl(40 10% 62%);
    --text-tertiary:  hsl(40 6%  45%);
    --text-muted:     hsl(40 4%  32%);
    --text-inverse:   hsl(220 14% 7%);

    /* Brand — ámbar cálido */
    --amber:        hsl(42 95% 55%);
    --amber-dim:    hsl(42 80% 42%);
    --amber-glow:   hsl(42 95% 55% / 0.12);
    --amber-subtle: hsl(42 95% 55% / 0.06);

    /* Semantic */
    --success: hsl(150 55% 42%);
    --warning: hsl(38  90% 52%);
    --error:   hsl(0   65% 52%);
    --error-bg: hsl(0  40% 12%);

    /* Typography */
    --font-display: 'DM Serif Display', Georgia, serif;
    --font-body:    'Instrument Sans', system-ui, sans-serif;
    --font-mono:    'JetBrains Mono', 'Fira Code', monospace;

    /* Spacing scale (base 4px) */
    --sp-1:  4px;
    --sp-2:  8px;
    --sp-3: 12px;
    --sp-4: 16px;
    --sp-5: 20px;
    --sp-6: 24px;
    --sp-8: 32px;
    --sp-10: 40px;
    --sp-12: 48px;
    --sp-16: 64px;
    --sp-20: 80px;

    /* Border radius */
    --radius-sm: 4px;
    --radius-md: 8px;
    --radius-lg: 12px;
    --radius-xl: 18px;

    /* Transitions */
    --ease-out: cubic-bezier(0.22, 1, 0.36, 1);
  }

  /* ── Skeleton Loaders (Shared) ─────────────────────────────────────────────── */
  .skel {
    position: relative;
    background: var(--bg-overlay);
    overflow: hidden;
    border-radius: var(--radius-sm);
  }
  .skel::after {
    content: '';
    position: absolute;
    inset: 0;
    transform: translateX(-100%);
    background: linear-gradient(90deg, transparent, rgba(255, 180, 50, 0.15), transparent);
    animation: scan 1.5s infinite ease-in-out;
  }
  @keyframes scan {
    100% { transform: translateX(100%); }
  }

  /* ── Shared Card Headers ───────────────────────────────────────────────────── */
  .card-header { margin-bottom: var(--sp-6); }
  .card-tag {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.12em;
    color: var(--amber);
    margin-bottom: var(--sp-1);
  }
  .card-title {
    font-family: var(--font-display);
    font-size: clamp(1.3rem, 3vw, 1.7rem);
    font-weight: 400;
    color: var(--text-primary);
    line-height: 1.2;
    margin-bottom: var(--sp-1);
  }
  .card-subtitle {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--text-tertiary);
  }

  /* ── Reset ─────────────────────────────────────────────────────────────────── */
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  html {
    background: var(--bg-canvas);
    color: var(--text-primary);
    font-family: var(--font-body);
    font-size: 16px;
    line-height: 1.6;
    -webkit-font-smoothing: antialiased;
    scroll-behavior: smooth;
  }

  body {
    min-height: 100dvh;
    background:
      radial-gradient(ellipse 80% 60% at 50% -10%, hsl(42 60% 15% / 0.25) 0%, transparent 65%),
      var(--bg-canvas);
  }

  /* Grain overlay  */
  body::before {
    content: '';
    position: fixed;
    inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.035'/%3E%3C/svg%3E");
    pointer-events: none;
    z-index: 9999;
    opacity: 0.5;
  }

  img, svg { display: block; max-width: 100%; }

  a { color: var(--amber); text-decoration: none; }
  a:hover { text-decoration: underline; }

  /* ── Scrollbar ─────────────────────────────────────────────────────────────── */
  ::-webkit-scrollbar { width: 6px; height: 6px; }
  ::-webkit-scrollbar-track { background: var(--bg-canvas); }
  ::-webkit-scrollbar-thumb { background: var(--border-emphasis); border-radius: 99px; }

  /* ── Utility classes ───────────────────────────────────────────────────────── */
  .visually-hidden {
    position: absolute;
    width: 1px; height: 1px;
    overflow: hidden;
    clip: rect(0 0 0 0);
    white-space: nowrap;
  }
</style>
